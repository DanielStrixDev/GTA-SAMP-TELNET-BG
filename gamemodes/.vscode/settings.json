{
    // 1. Задължително: Кодировка за всички файлове
    "files.encoding": "windows1251",
    
    // 2. Задължително: Изключи автоматичното отгатване, за да не ти сменя кодировкита
    //    VS Code често греши с кирилицата и започва да меша кодировки.
    "files.autoGuessEncoding": false,
    
    // 3. Задължително за новите файлове: Новият празен файл да е веднага в win1251
    "files.defaultLanguage": "pawn", // или "pawn" ако имаш инсталиран extension
}